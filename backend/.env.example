# ============================================================
# MyLokalEvent — Environment Variables
# Copy this file to ".env" and fill in your real values.
# NEVER commit the real .env to git.
# ============================================================

# --- App ---
APP_NAME=MyLokalEvent
# Public base URL of the deployed app (used for payment callbacks & email links).
# Local dev: http://localhost:8000  |  Production: https://your-app.onrender.com
BASE_URL=http://localhost:8000
# Comma-separated list of allowed frontend origins for CORS.
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# --- JWT / Security ---
# Generate a strong random key:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-long-random-hex-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
# Account lockout policy
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15

# --- Supabase (Project Settings -> API) ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Use the SERVICE ROLE key on the server (full DB access, bypasses RLS).
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
# Storage bucket name for event banners & ad images (create it in Supabase Storage).
SUPABASE_STORAGE_BUCKET=uploads

# --- ToyyibPay (https://toyyibpay.com -> Settings) ---
# Use the SANDBOX endpoint while testing: https://dev.toyyibpay.com
TOYYIBPAY_BASE_URL=https://dev.toyyibpay.com
TOYYIBPAY_SECRET_KEY=your-toyyibpay-secret-key
TOYYIBPAY_CATEGORY_CODE=your-toyyibpay-category-code

# --- SendGrid (https://app.sendgrid.com -> Settings -> API Keys) ---
SENDGRID_API_KEY=your-sendgrid-api-key
# FROM_EMAIL must be a SendGrid *verified sender* or the send is rejected.
SENDGRID_FROM_EMAIL=no-reply@yourdomain.com
SENDGRID_FROM_NAME=MyLokalEvent
# Demo redirect: emails addressed to seeded @demo.mylokalevent.my / admin accounts
# (which can't receive real mail) are re-routed here so they're visible in a demo.
# Real registered users always get their own email. REQUIRED on the deployed host
# for demo-account approval emails to actually arrive — otherwise they vanish.
DEMO_EMAIL_REDIRECT=your-demo-inbox@example.com

# --- OpenWeatherMap (https://openweathermap.org/api) ---
OPENWEATHER_API_KEY=your-openweathermap-api-key

# --- Feature flags ---
# Set to "true" to mock external services (no real API calls) for offline testing.
MOCK_PAYMENTS=false
MOCK_EMAIL=false
MOCK_WEATHER=false
